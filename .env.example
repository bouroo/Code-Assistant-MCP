# Server Configuration
MCP_SERVER_NAME=code-assistant-mcp
MCP_SERVER_VERSION=1.0.0

# Transport Configuration
MCP_TRANSPORT_STDIO=true
MCP_TRANSPORT_HTTP=false
MCP_HTTP_PORT=3000
MCP_HTTP_HOST=localhost

# GitHub Token (optional - increases rate limits for doc-search tool)
# Get your token at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# HTTP Authentication (optional)
MCP_HTTP_AUTH_ENABLED=false
MCP_HTTP_API_KEY=your_api_key_here

# Logging Configuration
LOG_LEVEL=info

# File Operations - Allowed Directories (comma-separated)
# Default: current directory only
# Example: MCP_ALLOWED_DIRS=/path/to/project1,/path/to/project2
# MCP_ALLOWED_DIRS=.
