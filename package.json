{
  "name": "coder-agent-mcp",
  "version": "1.0.0",
  "description": "Lightweight MCP server for coder agents with web search, docs search, and coding tools",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "coder-agent-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "bun run dist/index.js",
    "dev": "bun run --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.24.0",
    "duck-duck-scrape": "^2.0.0",
    "cheerio": "^1.0.0",
    "@octokit/rest": "^21.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "coder-agent",
    "web-search",
    "github"
  ],
  "license": "MIT"
}
