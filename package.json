{
  "name": "code-assistant-mcp",
  "version": "1.0.1",
  "description": "Production-ready MCP server for AI coding assistants",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "type": "module",
  "bin": "dist/index.js",
  "files": ["dist"],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "build": "bun build src/index.ts --outdir dist --target bun && printf '#!/usr/bin/env bun\\n' | cat - dist/index.js > temp.js && mv temp.js dist/index.js && chmod +x dist/index.js",
    "prepare": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@octokit/rest": "^22.0.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "turndown": "^7.2.2",
    "zod": "3.23.8",
    "zod-to-json-schema": "3.23.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
